# LLM API Keys Configuration
# 复制此文件为 .env 并填入您的API密钥

# Deepseek API
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# Qwen (阿里云通义千问)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# 腾讯混元（OpenAI 兼容接口，见 https://cloud.tencent.com/document/product/1729/111007 ）
HUNYUAN_API_KEY=your_hunyuan_api_key_here
# HUNYUAN_API_BASE=https://api.hunyuan.cloud.tencent.com/v1

# Google AI Studio (Gemini)
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI (可选，用于GraphRAG默认配置)
OPENAI_API_KEY=your_openai_api_key_here

# 智谱 GLM（graph_builder 已支持）
# GLM_API_KEY=your_glm_api_key_here

# 默认使用的LLM模型
DEFAULT_LLM_PROVIDER=hunyuan
DEFAULT_LLM_MODEL=hunyuan-lite

# 使用 Ollama 本地模型（无需 API 密钥）
# DEFAULT_LLM_PROVIDER=ollama
# DEFAULT_LLM_MODEL=qwen3:32b
# OLLAMA_API_BASE=http://localhost:11434


# 数标标（test分支可选）
# SHUBIAOBIAO_API_KEY=
# SHUBIAOBIAO_API_BASE=https://hk.n1n.ai/v1

# GraphRAG配置
GRAPHRAG_INPUT_DIR=./data/input
GRAPHRAG_OUTPUT_DIR=./data/output

# Plain vector RAG baseline
PLAIN_RAG_INPUT_DIR=./data/graphrag_output/input
# Keep plain RAG aligned with the current GraphRAG embedding config by default.
PLAIN_RAG_EMBEDDING_BACKEND=ollama
PLAIN_RAG_EMBEDDING_MODEL=nomic-embed-text
PLAIN_RAG_CACHE_DIR=./data/plain_vector_rag_cache
