[
  {
    "id": "M02_001",
    "chapter": "序·历史背景",
    "historical_tag": [
      "文化大革命",
      "红卫兵",
      "1966年8月"
    ],
    "original_text": "思想兵是保守派组织“毛泽东思想红卫兵”的简称。"
  },
  {
    "id": "M02_002",
    "chapter": "序·历史背景",
    "historical_tag": [
      "文化大革命",
      "重庆武斗",
      "保皇派"
    ],
    "original_text": "保皇有功，麻饼两封；保皇有赏，麻饼二两；铁竿保皇，铺盖两床。"
  },
  {
    "id": "M02_003",
    "chapter": "战报创刊",
    "historical_tag": [
      "八一五事件",
      "1966年12月",
      "重庆体育场"
    ],
    "original_text": "创刊号是１９６６年１２月９日出版的。该报出版前五天，即１２月４日，在重庆大田湾体育场发生了届时为止全国最大规模的武斗血案。"
  },
  {
    "id": "M02_004",
    "chapter": "1·2·4血案",
    "historical_tag": [
      "1964年",
      "中央工作会议",
      "文化大革命"
    ],
    "original_text": "中央工作会议后，各级党委纷纷检讨自己“执行了资产阶级反动路线”，“犯了方向性、路线性错误”。"
  },
  {
    "id": "M02_005",
    "chapter": "1·2·4血案",
    "historical_tag": [
      "保皇派",
      "工人纠察队",
      "1966年12月4日"
    ],
    "original_text": "１１月２８日，重庆全城同时飞传一张《海报》，称：“重庆工人战斗军”司令部定于１２月４日在重庆体育场召开“高举毛泽东思想伟大红旗，深入揭发批判西南局、省市委所执行的资产阶级反动路线誓师大会”。"
  },
  {
    "id": "M02_006",
    "chapter": "1·2·4血案",
    "historical_tag": [
      "工人纠察队",
      "李井泉",
      "西南局"
    ],
    "original_text": "重庆的官办组织有四个，学生中有三个:“毛泽东思想红卫兵”、“毛泽东思想红小兵”、“赤卫军”。赤卫军为“思想兵”的外围组织，成员均为出身成份较差者。"
  },
  {
    "id": "M02_007",
    "chapter": "1·2·4血案",
    "historical_tag": [
      "郑全体",
      "八一五",
      "智擒李井泉"
    ],
    "original_text": "全国有名的“智擒李井泉”事件，首席执行人就是他。毕业后分配广东平石矿务局挖煤，多次创造日掘进尺的新纪录。"
  },
  {
    "id": "M02_008",
    "chapter": "1·2·4血案",
    "historical_tag": [
      "1966年12月4日",
      "大田湾体育场",
      "武斗血案"
    ],
    "original_text": "人山人海的大田湾体育场里，两派冲突已经开始。台上台下数万群众，开始是喊叫、谩骂、吐口水，马上升级为推搡、为扭扯，为撕打。"
  },
  {
    "id": "M02_009",
    "chapter": "1·2·4血案",
    "historical_tag": [
      "1966年11月27日",
      "渣滓洞大屠杀",
      "红岩"
    ],
    "original_text": "１１月２７日，这是解放前夕国民党制造著名的“渣滓洞”大屠杀的死难纪念日。由于《红岩》这部小说和由小说改编的电影《烈火中永生》在年轻人的心目中影响太深。"
  },
  {
    "id": "M02_010",
    "chapter": "罗广斌其人",
    "historical_tag": [
      "罗广斌",
      "红岩作者",
      "文化大革命"
    ],
    "original_text": "罗广斌在１２５大会的发言中有这样一段话：“一个星期以前，我们在这儿追悼牺牲在中美合作所里的革命先烈，一个星期以后的今天，我们又在这儿追悼牺牲在重庆体育场的无产阶级革命造反英雄。”"
  },
  {
    "id": "M02_011",
    "chapter": "罗广斌其人",
    "historical_tag": [
      "1963年",
      "共青团中央",
      "罗广斌"
    ],
    "original_text": "１９６３年，罗的名气已如日中天，共青团中央提议推选罗广斌为全国青联访日代表，被“历史问题有个别疑点”一句话便轻易否决。"
  },
  {
    "id": "M02_012",
    "chapter": "工人造反风潮",
    "historical_tag": [
      "1966年10月",
      "中央工作会议",
      "工人阶级"
    ],
    "original_text": "１９６６年10 月中央工作会议后，重庆市委马上诚惶诚恐地召开了“三级干部会议”进行贯彻，情愿或者不情愿地认真检讨前一阶段的“方向性、路线性错误”。"
  },
  {
    "id": "M02_013",
    "chapter": "工人造反风潮",
    "historical_tag": [
      "1966年11月",
      "红工815",
      "红岩831"
    ],
    "original_text": "居民８１５战斗团、供电８３０、红岩８３１战斗团、重纺８１５战斗团……都在革命的喊杀声中象雨后春笋般地出现了！"
  },
  {
    "id": "M02_014",
    "chapter": "山城战报",
    "historical_tag": [
      "1967年3月",
      "革联会",
      "山城战报"
    ],
    "original_text": "决定创办《山城战报》是革联会３月５日会议上决定的。根据我日记的记录，“鉴于如下三个原因”，革联会要求各学校和组织的小报一律停办。"
  },
  {
    "id": "M02_015",
    "chapter": "山城战报",
    "historical_tag": [
      "1967年3月14日",
      "创刊号",
      "毛泽东思想"
    ],
    "original_text": "报纸是３月１４日创刊的。由于有专业人士参加，又在《重庆日报》正而八经的专业印刷厂印刷，从版面安排、版式、质量、字体多样性、美术水平等方面都可以看得出来，这份报纸是很有专业水准的。"
  },
  {
    "id": "M02_016",
    "chapter": "迷惑与动摇",
    "historical_tag": [
      "1967年3月16日",
      "二月逆流",
      "王力"
    ],
    "original_text": "３月１６日这一天，报社让我和黄天俊去天府煤矿采访一个大会。天府煤矿很远，从市区到了北碚，过嘉陵江，还要坐好长一段小火车才能抵达。"
  },
  {
    "id": "M02_017",
    "chapter": "迷惑与动摇",
    "historical_tag": [
      "1967年3月8日",
      "西师831",
      "反到底派"
    ],
    "original_text": "３月８日，西师８３１垮台，头头被抓，对于它的“红色根据地”意味着什么，已经不言自明了。"
  },
  {
    "id": "M02_018",
    "chapter": "陷入动荡",
    "historical_tag": [
      "1967年3月31日",
      "资本主义复辟",
      "游行"
    ],
    "original_text": "３月３１日。不平静的夜。同学们不顾总团某些人的阻拦，征集签名，准备次日大游行，粉碎资本主义复辟逆流。"
  },
  {
    "id": "M02_019",
    "chapter": "陷入动荡",
    "historical_tag": [
      "1967年4月2日",
      "人民日报",
      "革命小将"
    ],
    "original_text": "４月２日。人民日报社论《正确对待革命小将》发表，大大鼓舞了革命造反派，我们这一群为西师、交院早就抱不平的八一五，心里感到无限兴奋。"
  },
  {
    "id": "M02_020",
    "chapter": "武斗升级",
    "historical_tag": [
      "1967年6月",
      "成都武斗",
      "产业军"
    ],
    "original_text": "解决四川问题的十条是五月六日下达，就在当天，成都发生了造反派冲击飞机制造厂而该厂保卫人员开枪还击，打死打伤数百人的流血事件。"
  },
  {
    "id": "M02_021",
    "chapter": "七月山城",
    "historical_tag": [
      "1967年7月",
      "武器",
      "重庆军工厂"
    ],
    "original_text": "据可以相信的资料记录，1967 年7 月，反到底派一次就从兵工厂把“一万二、三千条新式武器发出来扩散到外面”，所谓“反到底舰队”，三只船上均装备了大炮。"
  },
  {
    "id": "M02_022",
    "chapter": "七月山城",
    "historical_tag": [
      "1967年7月1日",
      "重庆医学院",
      "武斗"
    ],
    "original_text": "７月１日，两派在重庆医学院附属一院再次武斗，使用钢千、刺刀、自制燃烧弹，死二人，伤数十人，附属一院门诊部被迫全天停诊。"
  },
  {
    "id": "M02_023",
    "chapter": "血火初起",
    "historical_tag": [
      "1967年6月23日",
      "重医附小",
      "武斗事件"
    ],
    "original_text": "１９６７年６月２３日，便有了双方由上百人参加的重医附小武斗事件。此役死四人，伤百余人。"
  },
  {
    "id": "M02_024",
    "chapter": "钦差大臣",
    "historical_tag": [
      "1967年7月13日",
      "谢富治",
      "王力"
    ],
    "original_text": "中央文革的钦差大臣谢富治、王力，还有空军政委余立金带着几个“北航红旗”的学生到西南巡游来了。他们是６月２７日第一站到达昆明的。"
  },
  {
    "id": "M02_025",
    "chapter": "钦差大臣",
    "historical_tag": [
      "1967年7月18日",
      "毛泽东",
      "文攻武卫"
    ],
    "original_text": "７月１８日，即王力重庆讲话后的第四天，毛在武汉召见周恩来、王力等人便明确说：“为什么不能把工人、学生武装起来？我看要把他们武装起来。”"
  },
  {
    "id": "M02_026",
    "chapter": "钦差大臣",
    "historical_tag": [
      "1967年7月22日",
      "江青",
      "文攻武卫"
    ],
    "original_text": "七月二十二日凌晨，怒气冲冲的江青在北京接见河南群众组织及其他方面代表，明确肯定了“文攻武卫”的口号。"
  },
  {
    "id": "M02_027",
    "chapter": "我的记忆中的死者",
    "historical_tag": [
      "1967年8月",
      "烈士陵园",
      "松林坡"
    ],
    "original_text": "１９６７年秋天，没有死的同学就在草坪中央挖了一个大坑，将被枪弹打死的同学尸体一具具窖下去，埋上黄土，为墓地砌成了围栏。"
  },
  {
    "id": "M02_028",
    "chapter": "必胜出炉",
    "historical_tag": [
      "1967年11月5日",
      "八一五风暴",
      "人民大礼堂"
    ],
    "original_text": "修改版首演时间是11 月5 日，地点是人民大礼堂。成都军区司令员梁兴初、中央调查组组长陈斌及驻军首长全体出席观看并接见全体演职员。"
  },
  {
    "id": "M02_029",
    "chapter": "必胜出炉",
    "historical_tag": [
      "1967年12月10日",
      "慰问团",
      "八一五派"
    ],
    "original_text": "全川各地的八一五派这时都走亲戚一样，纷纷来重庆聚会，兴高采烈，弹冠相庆。据１２月１０日出版的第５１期《８１５战报》报导，前来串门的友好团体计有各地赴渝慰问团。"
  },
  {
    "id": "M02_030",
    "chapter": "必胜出炉",
    "historical_tag": [
      "1967年9月至12月",
      "四川倒刘张运动",
      "梁兴初"
    ],
    "original_text": "梁兴初是“四野”虎将，解放战争时期战功赫赫。五十四军也是四野的王牌之一。梁在五十四军的地盘上活动自然心情舒畅，如鱼之得水。"
  }
]