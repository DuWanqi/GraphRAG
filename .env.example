# ---------------------------------------------------------------------------
# 复制为 .env 并填入真实值。未使用的提供商可整段留空或注释掉。
# ---------------------------------------------------------------------------

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
# 可选：自定义 API 基址（代理/兼容端点）
# OPENAI_BASE_URL=https://api.openai.com/v1

# --- DeepSeek ---
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# --- Qwen（通义千问，OpenAI 兼容模式）---
# QWEN_API_KEY=your_qwen_api_key
# QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- 腾讯混元（OpenAI 兼容，控制台创建 API Key 即可；无需 SecretId/SecretKey）---
# HUNYUAN_API_KEY=your_hunyuan_api_key
# 可选：与官方默认一致时可不写
# HUNYUAN_API_BASE=https://api.hunyuan.cloud.tencent.com/v1

# --- Google Gemini ---
# GOOGLE_API_KEY=your_google_api_key
# SAFE 独立事实验证用的 Google 自定义搜索（可选）
# GOOGLE_CSE_ID=your_google_cse_id

# --- 智谱 GLM ---
# GLM_API_KEY=your_glm_api_key

# --- Ollama（本地）---
# OLLAMA_API_BASE=http://localhost:11434

# --- 数标标（可选分支）---
# SHUBIAOBIAO_API_KEY=your_shubiaobiao_api_key
# SHUBIAOBIAO_API_BASE=https://hk.n1n.ai/v1

# --- 默认 LLM（未在 UI 指定时使用）---
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_MODEL=gpt-4o

# --- GraphRAG 数据路径（默认指向项目下 data/）---
# GRAPHRAG_INPUT_DIR=data/input
# GRAPHRAG_OUTPUT_DIR=data/graphrag_output

# --- 普通向量 RAG baseline（默认读取 GraphRAG 原始输入，不读取图索引输出）---
# PLAIN_RAG_INPUT_DIR=data/graphrag_output/input
# PLAIN_RAG_EMBEDDING_BACKEND=ollama
# PLAIN_RAG_EMBEDDING_MODEL=nomic-embed-text
# PLAIN_RAG_CACHE_DIR=data/plain_vector_rag_cache

# --- Web 服务 ---
# APP_HOST=0.0.0.0
# APP_PORT=8000
# APP_DEBUG=false
